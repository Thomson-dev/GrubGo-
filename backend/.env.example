# ─── Shared secrets (same value across all services) ─────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_SECONDS=900
INTERNAL_API_KEY=change_this_to_another_long_random_string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── MongoDB (local Docker instance) ─────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=secret

# ─── Email / OTP (Gmail App Password) ────────────────────────────────────────
# 1. Enable 2-Factor Auth on your Gmail account
# 2. Go to myaccount.google.com/apppasswords → create App Password
# 3. Paste the 16-char app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Paystack (Nigerian payments) ────────────────────────────────────────────
# Get from dashboard.paystack.com → Settings → API Keys
# Test keys start with sk_test_ and pk_test_
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (international payments) ─────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
# Used once to create the first admin account via POST /api/admin/seed
# Remove or change after first use
ADMIN_SEED_SECRET=change_this_before_deploying

# ─── Frontend URL (for Paystack redirect after payment) ──────────────────────
FRONTEND_URL=http://localhost:3000

PORT=5006
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/admin-service
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_SECONDS=604800
INTERNAL_API_KEY=a_long_random_secret_for_service_to_service_calls
RESTAURANT_SERVICE_URL=http://localhost:5002
RIDER_SERVICE_URL=http://localhost:5005

# Bootstrap: create first admin account via POST /api/admin/seed
# Set a strong secret and remove this after first use
ADMIN_SEED_SECRET=change_this_before_deploying

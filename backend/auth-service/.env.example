PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/auth-service
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_SECONDS=900

# SMTP — for Gmail: use App Password (not your real password)
# Enable 2FA on your Google account, then generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

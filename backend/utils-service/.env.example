PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# Stripe — get from dashboard.stripe.com (test keys start with sk_test_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
